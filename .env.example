# Copy this file to ".env" and fill in your keys. ".env" is gitignored.

# Required — your Anthropic API key (https://console.anthropic.com/)
ANTHROPIC_API_KEY=sk-ant-...

# Optional — Claude model to use. Defaults to claude-opus-4-8.
# Use claude-sonnet-4-6 for a cheaper, faster option.
# ANTHROPIC_MODEL=claude-opus-4-8

# Optional — enables the news-search tool (https://tavily.com/)
# TAVILY_API_KEY=tvly-...

# Optional — local embedding model for RAG (no API key needed)
# EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
